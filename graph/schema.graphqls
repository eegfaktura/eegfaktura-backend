# GraphQL vfeeg-backend
#

scalar Eeg

type Link {
  id: ID!
  title: String!
  address: String!
}

input EegModel {
  tenant: String
  settlementInterval: String
  sepaActiv: Boolean
}


type Query {
  eeg: Eeg
  links: [Link!]!
}

type Mutation {
  updateEegModel(tenant: String!, eegModel: EegModel): Eeg
}